<Window x:Class="Wpf.ElementPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Element"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        Cursor="Cross"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">
    
    <Grid>
        <!-- Полупрозрачный фон -->
        <Rectangle Fill="#10000000"/>
        
        <!-- Увеличенная область под курсором -->
        <Border x:Name="MagnifierBorder" 
                Width="150" Height="150"
                CornerRadius="75"
                BorderBrush="White" 
                BorderThickness="2"
                Background="Transparent"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                IsHitTestVisible="False">
            
            <Grid Margin="0">
                <Border Background="Black" CornerRadius="75" Opacity="0.8"/>
                <Border x:Name="MagnifierContent" 
                        Width="140" Height="140"
                        CornerRadius="70"
                        ClipToBounds="True"
                        Background="Transparent"/>
                
                <!-- Крестик в центре -->
                <Line X1="65" Y1="70" X2="75" Y2="70" Stroke="Red" StrokeThickness="2"/>
                <Line X1="70" Y1="65" X2="70" Y2="75" Stroke="Red" StrokeThickness="2"/>
            </Grid>
        </Border>
        
        <!-- Текст подсказки -->
        <Border Background="#CC000000" 
                CornerRadius="5" 
                Padding="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,30"
                IsHitTestVisible="False">
            <TextBlock Foreground="White" FontSize="14">
                Click to select element | Press ESC to cancel
            </TextBlock>
        </Border>
    </Grid>
</Window>