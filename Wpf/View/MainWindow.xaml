<Window x:Class="Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ISeeU Monitor" 
        Height="450" 
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="Segoe UI">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#007ACC" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ISeeU" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text=" UI Monitor" FontSize="20" Foreground="#E0E0E0"/>
            </StackPanel>
        </Border>
        
        <!-- Панель статуса -->
        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5" 
                        Background="{Binding ElementName=StatusText, Path=Foreground}" Margin="0,0,10,0"/>
                <TextBlock x:Name="StatusText" Grid.Column="1" Text="Disconnected" Foreground="Red"/>
                <TextBlock x:Name="ElementCountText" Grid.Column="2" Text="Elements: 0" Foreground="Gray"/>
            </Grid>
        </Border>
        
        <!-- Кнопки -->
        <!-- Кнопки -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
    
            <!-- Левая группа -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="PickElementBtn" 
                        Click="PickElementBtn_Click" 
                        Width="100" Height="30"
                        Background="#007ACC" 
                        Foreground="White"
                        Cursor="Hand">
                    Pick Element
                </Button>
        
                <Button x:Name="SubscribeBtn" 
                        Click="SubscribeBtn_Click" 
                        Width="100" Height="30"
                        Margin="5,0,0,0"
                        Background="#4CAF50" 
                        Foreground="White"
                        Cursor="Hand">
                    Subscribe
                </Button>
        
                <Button x:Name="Unsubscribe" 
                        Click="UnsubscribeClick" 
                        Width="100" Height="30"
                        Margin="5,0,0,0"
                        Background="#D32F2F" 
                        Foreground="White"
                        Cursor="Hand">
                    Unsubscribe
                </Button>
            </StackPanel>
    
            <!-- Правая группа -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ClearAllBtn" 
                        Click="ClearAllBtn_Click" 
                        Width="100" Height="30"
                        Background="#D32F2F" 
                        Foreground="White"
                        Cursor="Hand">
                    Clear All
                </Button>
            </StackPanel>
        </Grid>        
        <!-- Список элементов + выбор свойств -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240"/>
            </Grid.ColumnDefinitions>

            <!-- Отслеживаемые элементы -->
            <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="5" Margin="0,0,10,0"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Monitored Elements" FontWeight="Bold" Margin="5"/>

                    <ListBox x:Name="ElementsList" Grid.Row="1" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ElementId}" FontSize="10" Foreground="Gray"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Выбор свойств для выбранного элемента -->
            <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="5"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Properties to monitor" FontWeight="Bold" Margin="5"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PropertiesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="5,3">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}"/>
                                            <TextBlock Text="{Binding KindLabel}" Foreground="Gray" FontSize="10" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Уведомления -->
        <Border Grid.Row="4" Background="White" CornerRadius="5" Padding="5" Margin="0,10,0,0"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Notifications" FontWeight="Bold" Margin="5"/>
                
                <ListBox x:Name="NotificationsList" Grid.Row="1" BorderThickness="0" Height="80">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="11" Foreground="#555"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>